# ----------------------------------------------------------------------------
# Performance Tracker — Environment Variables
# Copy this file to .env.local and fill in the values.
# ----------------------------------------------------------------------------

# MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>/performance_tracker?retryWrites=true&w=majority"

# JWT signing secret (use a long random string, e.g. `openssl rand -base64 48`)
JWT_SECRET="change-me-to-a-long-random-secret"
# Session lifetime
JWT_EXPIRES_IN="7d"

# Default admin (used by the seed script on first run)
SEED_ADMIN_EMAIL="product@alltake.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Administrator"

# ---- SMTP2GO (SMTP credentials are NOT editable from the UI) ----
SMTP_HOST="mail.smtp2go.com"
SMTP_PORT="587"
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME="Performance Tracker"

# Vercel Cron secret (must match x-vercel-cron-secret in vercel.json)
CRON_SECRET="HhLhDMZh3e4/ehB6yy9rpePkzW1v5ElzINRgdNEHcbM="

# Absolute base URL of the app (used in emails / PDF asset resolution)
APP_BASE_URL="http://localhost:3000"

# Local storage directories (relative to project root)
UPLOADS_DIR="uploads"
